%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogues_pt
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: pt
  m_SharedData: {fileID: 11400000, guid: 1fefec8ee1412874da12e925cdeb9674, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 19197458069606400
    m_Localized: "Ah...minha cabe\xE7a..."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772224
    m_Localized: Ei! Preciso de ajuda!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772225
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772226
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772227
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772228
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772229
    m_Localized: "Opa, c\xEA finalmente acordou. Como t\xE1 a cuca?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772230
    m_Localized: Uhh ta doendo...
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772231
    m_Localized: "Mas \xE9 claro. Tentei te arruma o m\xE1ximo que deu mas, eu num
      sou m\xE9dico."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772232
    m_Localized: "C\xEA tava bem mal quando te achei."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772233
    m_Localized: "Num \xE9 todo dia que encontro gente desmaiada no meio da rua com
      a cabe\xE7a toda machucada."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772234
    m_Localized: "Eu... Ah \xE9! Teve um acidente!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772235
    m_Localized: Um trem quase acertou nosso carro, a gente teve que desviar pra
      fora da estrada!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772236
    m_Localized: "Voc\xEA chegou a ver meus amigos por a\xED? Quando eu acordei do
      acidente todos tinham sumido!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772237
    m_Localized: "Um trem c\xEA diz..."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772238
    m_Localized: "Bem, minha mem\xF3ria n\xE3o \xE9 mais t\xE3o boa quanto era antes,
      sabe?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772239
    m_Localized: "Mas eu acho que vi o Policial levando um rapaz de bon\xE9 e \xF3culos
      escuros..."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772240
    m_Localized: "Esse \xE9 o <#2271b3>Marcos</color>, certeza!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772241
    m_Localized: "Muito obrigada, senhor! Eu j\xE1 vou indo!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772242
    m_Localized: "S\xF3 um segundo a\xED, mocinha!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772243
    m_Localized: "C\xEA t\xE1 toda machucada. O que acontece se c\xEA come\xE7ar
      a se sentir mal de novo?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772244
    m_Localized: Obrigada por se preocupar, mas eu vou ficar bem.
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772245
    m_Localized: "Olha, c\xEA n\xE3o conhece essa cidade."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772246
    m_Localized: "S\xF3 confia em mim e pega a <#e35540>chave reserva</color> do
      Restaurante. Deve estar aqui atr\xE1s na despensa."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772247
    m_Localized: "Faz um bom tempo que abrimos, ent\xE3o eu num lembro da senha.
      Acho que deve ter uma nota pra isso."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772248
    m_Localized: "O Restaurante t\xE1... \"fechado\" por enquanto, mas pelo menos
      assim voc\xEA pode voltar se precisar."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772249
    m_Localized: "Ah n\xE3o precisa mesmo, obrigada-"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772250
    m_Localized: "Eu insisto. C\xEA num vai sair sem ela."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772251
    m_Localized: "De qualquer jeito, a porta t\xE1 trancada."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772252
    m_Localized: "...T\xE1."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772253
    m_Localized: Essa deve ser a <color=#e35540>chave reserva</color>.
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772254
    m_Localized: Nosso carro bateu, por favor ajuda!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772255
    m_Localized: "Pera, antes de c\xEA ir."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772256
    m_Localized: "Eu num sei como nem por que c\xEA veio pra essa cidade."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772257
    m_Localized: "Mas ela realmente num \xE9 mais como antes..."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772258
    m_Localized: "Eu sugiro c\xEA n\xE3o ficar mais do que precisa."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772259
    m_Localized: "E se c\xEA encontrar...algo estranho por a\xED, <#e35540>se esconda</color>."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772260
    m_Localized: "(Eu n\xE3o sei se devia confiar nele...)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772261
    m_Localized: (Mas...ele me ajudou...)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772262
    m_Localized: (De qualquer forma, melhor focar em achar o <#2271b3>Marcos</color>
      por hora!)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772263
    m_Localized: Ahn... Pra onde ela foi?
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772264
    m_Localized: "O que \xE9 isso..?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772265
    m_Localized: "N\xE3o venha..."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772266
    m_Localized: FIQUE LONGE!!!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772267
    m_Localized: "(J\xE1 est\xE1 carregado!)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772268
    m_Localized: "O que aconteceu?...Cad\xEA todo mundo?!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772269
    m_Localized: O Joca deve estar uma fera...
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772270
    m_Localized: Tenho que achar eles!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772271
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772272
    m_Localized: (Parece que alguma porta foi destrancada!)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772273
    m_Localized: (Ainda tem algo errado...)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772274
    m_Localized: "O port\xE3o parece bem enferrujado, mas eu n\xE3o consigo abrir
      ele s\xF3 com as m\xE3os."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772275
    m_Localized: "\xD4 nerd! Tem certeza de que esse \xE9 o lugar certo?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772276
    m_Localized: Claro! Cheguei a confirmar isso com o Joca ontem!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772277
    m_Localized: "Hm...s\xF3 espero que ele n\xE3o demore!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772278
    m_Localized: Opa galera! Todos a bordo!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772279
    m_Localized: "E a\xED? J\xE1 estamos chegando?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772280
    m_Localized: Estamos sim!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772281
    m_Localized: "Mas ent\xE3o, o que fez voc\xEA querer vir a esse fim de mundo?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772282
    m_Localized: Ivayami? Eu li sobre ela em uma postagem sobre cidades fantasmas.
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772283
    m_Localized: "Pelo que disseram, a cidade era um ponto de alto fluxo de trens,
      at\xE9 que um dia, aconteceu um grande inc\xEAndio na esta\xE7\xE3o."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772284
    m_Localized: "Desde ent\xE3o, parece que todos abandonaram o lugar, e dizem que
      quem ficou enlouqueceu! Isso n\xE3o \xE9 legal?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772285
    m_Localized: Ah, sim... Muito...
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772286
    m_Localized: "Contanto que essa belezinha aqui n\xE3o pegue fogo eu t\xF4 tranquilo!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772287
    m_Localized: "Pararam pra pensar que somos quatro jovens indo investigar um mist\xE9rio?
      S\xF3 falta um cachorro falante!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772288
    m_Localized: "Voc\xEA devia ter trazido o seu, Lu!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772289
    m_Localized: Nunca que eu trago o Floquinho pra um lugar desses!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772290
    m_Localized: Hahahahaha!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772291
    m_Localized: JOCA, CUIDADO!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772292
    m_Localized: Por que tem um buraco na parede?
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772293
    m_Localized: "Isso me d\xE1 uma ideia! Bora pra sala de evid\xEAncias."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772294
    m_Localized: "Temos que discutir longe da porta pra ter certeza de que ele n\xE3o
      vai ouvir."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772295
    m_Localized: (Por que tem um buraco na parede?)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772296
    m_Localized: "Seguinte, bora trancar o Policial na Sala de Interrogat\xF3rio!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772297
    m_Localized: "Voc\xEA atrai ele pra dentro e sai pelo buraco. A\xED eu tranco
      o desgra\xE7ado!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772298
    m_Localized: "Vou ficar em posi\xE7\xE3o at\xE9 ver que o Policial mordeu a isca."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772299
    m_Localized: "Assim que voc\xEA passar pelo buraco, eu puxo a alavanca!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772300
    m_Localized: "(N\xE3o tenho baterias para usar ele agora)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772301
    m_Localized: "(A porta n\xE3o se mexe.)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772302
    m_Localized: "(A fechadura parece selada. Talvez essa porta n\xE3o abra com uma
      chave?)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772303
    m_Localized: "Essas t\xE1buas parecem meio soltas, mas eu n\xE3o consigo tirar
      s\xF3 com as m\xE3os!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772304
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772305
    m_Localized: (Tinha uma chave embaixo do vaso. Mas onde que ela abre?)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772306
    m_Localized: "(N\xE3o tem nada embaixo do vaso.)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772307
    m_Localized: "(Parece ter um mecanismo aqui, mas est\xE1 travado.)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772308
    m_Localized: "Ah n\xE3o, o martelo quebrou..."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772309
    m_Localized: "(A porta est\xE1 trancada)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772310
    m_Localized: (Parece que tem algum mecanismo bloqueado a porta)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772311
    m_Localized: "A\xEA, deu certo!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772312
    m_Localized: Vambora daqui!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772313
    m_Localized: "(\xF3timo a for\xE7a da casa acabou)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772314
    m_Localized: "(Tenho de concertar a caixa de for\xE7a de algum jeito)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772315
    m_Localized: "(Eu n\xE3o posso entrar aqui antes de concertar a caixa de for\xE7a)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772316
    m_Localized: (Melhor guardar pra quando eu precisar)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772317
    m_Localized: Seguindo a direita, casa murada! SOME LOGO DAQUI!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772318
    m_Localized: "Eu <color=red>escutei uma porta</color> abrir, QUEM T\xC1 AI!!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772319
    m_Localized: (Eu preciso <color=red>achar o Marcos</color> e sair daqui)
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772320
    m_Localized: "Com licen\xE7a... senhor!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772321
    m_Localized: "Hm?! Que \xE9, menina?!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772322
    m_Localized: "...Meu amigo, <#2271b3>Marcos</color>...ele est\xE1 aqui?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772323
    m_Localized: "Se estiver, com certeza tem um bom motivo, n\xE3o acha?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772324
    m_Localized: "Eu...n\xE3o sei! Ele fez algo de errado?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772325
    m_Localized: "\"Ele\", \"ele\"...eu sei l\xE1 quem \xE9 \"ele\"! S\xE3o todos
      iguais!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772326
    m_Localized: Mas eu-
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772327
    m_Localized: "Olha, eu to fazendo meu trabalho, t\xE1 legal?! Se quiser, <#e35540>vai
      encher o saco do Delegado!</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772328
    m_Localized: "Saindo daqui, segue \xE0 direita toda vida at\xE9 ver uma casa
      toda murada!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772329
    m_Localized: "AGORA SOME DAQUI! N\xE3o vou repetir!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772330
    m_Localized: Achou a chave?
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772331
    m_Localized: "A <#e35540>chave</color> t\xE1 ali atr\xE1s, na dispensa. C\xEA
      achou a <#e35540>nota</color>?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772332
    m_Localized: "J\xE1 encontrou seu amigo?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772333
    m_Localized: "Se o Policial levou seu amigo, deve t\xE1 na Delegacia. Se cuida,
      menina!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772334
    m_Localized: Olha, Cynthia...valeu pela ajuda.
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772335
    m_Localized: "Claro...foi ideia minha vir pra c\xE1, ent\xE3o n\xE3o podia simplesmente
      abandonar voc\xEAs."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772336
    m_Localized: "Na verdade podia. E fico feliz que n\xE3o fez."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772337
    m_Localized: "...\xC9...esse lugar mexe com a nossa cabe\xE7a!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772338
    m_Localized: Pode crer...algum sinal dos outros?
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772339
    m_Localized: "Ainda n\xE3o...mas vamos embora daqui!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772340
    m_Localized: Certo, a gente precisa de um jeito de se livrar do Policial.
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772341
    m_Localized: "Hm...sabe algo daquele buraco na Sala de Interrogat\xF3rio?"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772342
    m_Localized: "N\xE3o, mas isso me deu uma ideia! Podemos atrair o Policial at\xE9
      a sala e prender ele l\xE1 dentro!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772343
    m_Localized: "Eu fico na porta e, quando voc\xEA passar pelo buraco, eu prendo
      o desgra\xE7ado!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772344
    m_Localized: Okay...vai servir!
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772345
    m_Localized: Olha, Cynthia...valeu pela ajuda.
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772346
    m_Localized: "Claro...foi ideia minha vir pra c\xE1, ent\xE3o n\xE3o podia simplesmente
      abandonar voc\xEAs."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772347
    m_Localized: "Na verdade podia. E fico feliz que n\xE3o fez."
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772348
    m_Localized: "...\xC9...esse lugar mexe com a nossa cabe\xE7a!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772349
    m_Localized: Pode crer...algum sinal dos outros?
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772350
    m_Localized: "Ainda n\xE3o...mas vamos embora daqui!"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772351
    m_Localized: Certo, a gente precisa de um jeito de se livrar do Policial.
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772352
    m_Localized: "(Est\xE1 sem linha...)"
    m_Metadata:
      m_Items: []
  - m_Id: 19197458094772353
    m_Localized: "(Eu n\xE3o consigo mais abrir, acho que emperrou!)"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
